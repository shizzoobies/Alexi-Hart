---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const links = [
  { href: `${base}/`, label: "Home" },
  { href: `${base}/books`, label: "Books" },
  { href: `${base}/about`, label: "About" },
  { href: `${base}/blog`, label: "Blog" },
  { href: `${base}/members`, label: "Members" }
];
---

<nav class="max-w-3xl mx-auto px-6 py-6 flex items-center justify-between">
  <a href={`${base}/`} class="font-display text-xl">Alexi Hart</a>
  <ul class="flex gap-6 text-sm">
    {links.slice(1).map((l) => (
      <li><a href={l.href} class="hover:text-accent">{l.label}</a></li>
    ))}
  </ul>
</nav>
