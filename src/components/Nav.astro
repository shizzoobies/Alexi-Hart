---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const links = [
  { href: `${base}/`, label: "Home" },
  { href: `${base}/books`, label: "Books" },
  { href: `${base}/about`, label: "About" },
  { href: `${base}/blog`, label: "Blog" },
  { href: `${base}/members`, label: "Members" }
];
---

<header class="bg-surface/90 backdrop-blur-md border-b border-outline-variant/30 top-0 sticky z-50 shadow-sm shadow-on-surface/5">
  <nav class="flex justify-between items-center w-full max-w-container-max mx-auto px-md py-sm">
    <a class="font-headline-md text-headline-md italic text-primary hover:opacity-80 transition-all duration-300" href={`${base}/`}>Alexi Hart</a>
    <div class="hidden md:flex items-center gap-lg">
      {links.slice(1).map((l) => (
        <a class="text-on-surface-variant hover:text-primary transition-colors font-body-md text-body-md" href={l.href}>{l.label}</a>
      ))}
    </div>
    <a href={`${base}/members`} class="bg-primary text-on-primary px-md py-sm rounded-lg font-label-sm text-label-sm hover:opacity-80 transition-all duration-300">
      Join the List
    </a>
  </nav>
</header>
