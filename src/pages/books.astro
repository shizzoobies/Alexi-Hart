---
import BaseLayout from "~/layouts/BaseLayout.astro";
import catalog from "~/data/catalog.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const seriesEntries = Object.entries(catalog.series ?? {});

function fmtDate(s: string | undefined) {
  if (!s) return "";
  return new Date(s).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
}
---

<BaseLayout title="Books | Alexi Hart">
  <!-- Hero -->
  <section class="py-xl bg-surface-container-low">
    <div class="max-w-container-max mx-auto px-md text-center space-y-sm">
      <span class="font-label-sm text-label-sm uppercase tracking-widest text-secondary">The Catalog</span>
      <h1 class="font-headline-xl text-headline-xl text-primary">Books by Alexi Hart</h1>
      <p class="font-body-lg text-body-lg italic text-on-surface-variant max-w-2xl mx-auto">{catalog.tagline}</p>
    </div>
  </section>

  <!-- Series sections -->
  {seriesEntries.map(([slug, series]) => (
    <section class="py-xl border-b border-outline-variant/20">
      <div class="max-w-container-max mx-auto px-md">
        <header class="mb-lg space-y-xs">
          <div class="flex items-center gap-sm flex-wrap">
            <h2 class="font-headline-lg text-headline-lg text-primary">{series.name}</h2>
            <span class="font-label-sm text-label-sm uppercase tracking-widest text-secondary">{series.books.length} {series.books.length === 1 ? "book" : "books"}</span>
          </div>
          {series.subtitle ? (
            <p class="font-body-md text-body-md italic text-on-surface-variant">{series.subtitle}</p>
          ) : null}
        </header>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-md">
          {series.books.map((b) => (
            <article class="group">
              <div class="aspect-[2/3] overflow-hidden bg-surface-container-low rounded-lg shadow-sm border border-outline-variant/20 group-hover:shadow-lg transition-shadow">
                {b.cover ? (
                  <img
                    src={`${base}/${b.cover}`}
                    alt={`Cover of ${b.title}`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-secondary-fixed via-surface-container-low to-secondary-fixed-dim">
                    <span class="material-symbols-outlined text-primary opacity-30" style="font-size: 48px;">auto_stories</span>
                  </div>
                )}
              </div>
              <div class="mt-sm space-y-xs">
                {b.number ? (
                  <p class="font-label-sm text-label-sm uppercase tracking-widest text-secondary">Book {b.number}</p>
                ) : null}
                <h3 class="font-headline-md text-base font-semibold text-on-surface leading-tight">{b.title}</h3>
                {b.subtitle ? (
                  <p class="font-body-md text-xs italic text-on-surface-variant">{b.subtitle}</p>
                ) : null}
                <div class="flex items-center gap-xs flex-wrap pt-xs">
                  {b.status === "preorder" ? (
                    <span class="bg-secondary-container text-on-secondary-container px-xs py-xs rounded-full font-label-sm text-[10px] uppercase tracking-widest">Pre-order</span>
                  ) : (
                    <span class="bg-primary/10 text-primary px-xs py-xs rounded-full font-label-sm text-[10px] uppercase tracking-widest">Available</span>
                  )}
                  {b.release_date ? (
                    <span class="font-label-sm text-[10px] text-on-surface-variant">{fmtDate(b.release_date)}</span>
                  ) : null}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Newsletter CTA -->
  <section class="py-xl bg-primary text-on-primary">
    <div class="max-w-container-max mx-auto px-md text-center space-y-sm">
      <h2 class="font-headline-lg text-headline-lg">Get the bonus story</h2>
      <p class="font-body-md text-body-md opacity-90 max-w-xl mx-auto">Subscribe for exclusive sneak peeks, deleted scenes, and a free Pelican Cove novella.</p>
      <a href={`${base}/members`} class="inline-block mt-sm bg-secondary-fixed text-on-secondary-fixed px-lg py-md rounded-lg font-label-sm text-label-sm uppercase tracking-widest hover:bg-secondary-fixed-dim transition-all">
        Join the Reader List
      </a>
    </div>
  </section>
</BaseLayout>
