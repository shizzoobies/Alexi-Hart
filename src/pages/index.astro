---
import BaseLayout from "~/layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="Alexi Hart | Contemporary Romance">
  <!-- Hero -->
  <section class="relative min-h-[640px] flex items-center overflow-hidden py-xl">
    <div class="absolute inset-0 z-0">
      <div class="w-full h-full bg-gradient-to-br from-secondary-fixed via-surface to-secondary-fixed-dim opacity-60"></div>
    </div>
    <div class="relative z-10 w-full max-w-container-max mx-auto px-md flex flex-col md:flex-row items-center gap-xl">
      <div class="flex-1 space-y-md">
        <span class="inline-block bg-secondary-container text-on-secondary-container px-sm py-xs rounded-full font-label-sm text-label-sm uppercase tracking-wider">New Series</span>
        <h1 class="font-headline-xl text-headline-xl text-primary max-w-lg">The Pelican Cove Series</h1>
        <p class="font-body-lg text-body-lg italic text-on-surface-variant max-w-md">Small town. Scorching heat. Absolutely no chill.</p>
        <p class="font-body-md text-body-md text-on-surface-variant max-w-md">
          Five standalone rom-coms set in one Florida Gulf-coast town. Funny, filthy, and full of heart. Start with The Worst Idea Yet.
        </p>
        <div class="flex gap-md pt-base flex-wrap">
          <a href={`${base}/books`} class="bg-primary text-on-primary px-lg py-md rounded-lg font-label-sm text-label-sm uppercase tracking-widest hover:opacity-90 transition-all shadow-md">Read the Series</a>
          <a href={`${base}/members`} class="border-2 border-primary text-primary px-lg py-md rounded-lg font-label-sm text-label-sm uppercase tracking-widest hover:bg-primary/5 transition-all">Get Bonus Story</a>
        </div>
      </div>
      <div class="flex-1 flex justify-center">
        <a href={`${base}/books`} class="relative group">
          <div class="absolute -inset-4 bg-secondary-fixed/50 rounded-xl blur-2xl group-hover:bg-secondary-fixed/70 transition-all"></div>
          <img
            src={`${base}/covers/the-worst-idea-yet.png`}
            alt="Cover of The Worst Idea Yet by Alexi Hart"
            class="relative w-[280px] md:w-[320px] aspect-[2/3] object-cover rounded-lg shadow-2xl border border-outline-variant/30 group-hover:-translate-y-2 transition-transform duration-500"
          />
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Book Section -->
  <section class="py-xl bg-surface-container-low scroll-mt-header" id="featured">
    <div class="max-w-container-max mx-auto px-md">
      <div class="grid md:grid-cols-12 gap-xl items-center">
        <div class="md:col-span-5 order-2 md:order-1">
          <div class="bg-surface p-md rounded-xl shadow-sm border border-outline-variant/20">
            <h3 class="font-headline-md text-headline-md text-primary mb-sm">What Readers Are Saying</h3>
            <div class="space-y-lg italic">
              <blockquote class="border-l-4 border-secondary-container pl-md py-base">
                <p class="font-body-md text-body-md text-on-surface-variant">"Alexi Hart writes the kind of small-town romance that makes you want to move there immediately."</p>
                <footer class="font-label-sm text-label-sm text-secondary mt-sm not-italic">Literary Loft Reviews</footer>
              </blockquote>
              <blockquote class="border-l-4 border-secondary-container pl-md py-base">
                <p class="font-body-md text-body-md text-on-surface-variant">"Funny, filthy, and full of heart. I devoured the whole series in a weekend."</p>
                <footer class="font-label-sm text-label-sm text-secondary mt-sm not-italic">Bookish Bliss</footer>
              </blockquote>
            </div>
          </div>
        </div>
        <div class="md:col-span-7 order-1 md:order-2 space-y-md">
          <span class="font-label-sm text-label-sm uppercase tracking-widest text-secondary">Series Opener</span>
          <h2 class="font-headline-lg text-headline-lg text-primary">The Worst Idea Yet</h2>
          <p class="font-body-lg text-body-lg italic text-on-surface-variant">She's been hired to save his bar. He'd rather let it burn than admit she's right.</p>
          <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
            When the Saltwater Bar and Grill's ten-year anniversary event threatens to be the thing that finally sinks the family business, Cole Calloway reluctantly agrees to hire an event planner. He expects someone competent and quiet. He gets Zoe Merritt: loud, brilliant, aggressively optimistic, and allergic to the word "no." She rearranges his supply closet on day one. He nearly has a stroke. By the end of the week, he can't stop watching her.
          </p>
          <div class="flex flex-wrap gap-sm pt-sm">
            <span class="bg-secondary-container/50 text-secondary px-sm py-xs rounded-full font-label-sm text-label-sm">Enemies to Lovers</span>
            <span class="bg-secondary-container/50 text-secondary px-sm py-xs rounded-full font-label-sm text-label-sm">Grumpy/Sunshine</span>
            <span class="bg-secondary-container/50 text-secondary px-sm py-xs rounded-full font-label-sm text-label-sm">Forced Proximity</span>
          </div>
          <div class="pt-lg flex items-center gap-md flex-wrap">
            <span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest">Available At</span>
            <div class="flex gap-md opacity-70 flex-wrap">
              <a href="https://www.amazon.com/author/alexihartbooks" class="font-headline-md text-headline-md hover:text-primary transition-colors">Amazon</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="py-xl scroll-mt-header" id="about-teaser">
    <div class="max-w-container-max mx-auto px-md">
      <div class="flex flex-col md:flex-row gap-xl items-center">
        <div class="md:w-1/2">
          <img
            src={`${base}/images/alexi-hart-cafe-writing.png`}
            alt="Alexi Hart writing in a cafe"
            class="rounded-xl shadow-lg border-4 border-surface w-full aspect-[4/5] object-cover"
          />
        </div>
        <div class="md:w-1/2 space-y-md">
          <h2 class="font-headline-lg text-headline-lg text-primary">A Note from Alexi</h2>
          <div class="space-y-sm font-body-md text-body-md text-on-surface-variant">
            <p>Hello! I'm Alexi, and I write the kind of romance I'd want to read on a beach: warm, witty, full of heart, and unafraid of the steamy parts. The Pelican Cove Series is set in a fictional Florida town where everybody is too invested in everybody else's business, and that is a feature, not a bug.</p>
            <p>When I'm not writing, you can find me chasing the perfect grouper sandwich, scouring antique bookstores, or trying (and failing) to bake the perfect macaron.</p>
          </div>
          <a href={`${base}/about`} class="inline-flex items-center gap-2 text-primary font-bold hover:gap-4 transition-all">
            Read more <span class="material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="py-xl bg-primary text-on-primary" id="newsletter">
    <div class="max-w-container-max mx-auto px-md text-center">
      <div class="max-w-2xl mx-auto space-y-md">
        <span class="material-symbols-outlined text-4xl" style="font-variation-settings: 'FILL' 1;">mail</span>
        <h2 class="font-headline-lg text-headline-lg">Join the Book Club</h2>
        <p class="font-body-md text-body-md opacity-90">Sign up for sneak peeks, deleted scenes, and the bonus Pelican Cove novella.</p>
        <form class="flex flex-col sm:flex-row gap-sm pt-md" action={`${base}/members`} method="get">
          <input class="flex-grow px-md py-sm rounded-lg border-none text-on-surface focus:ring-2 focus:ring-secondary-fixed" placeholder="Enter your email address" type="email" name="email" />
          <button class="bg-secondary-fixed text-on-secondary-fixed px-lg py-sm rounded-lg font-label-sm text-label-sm hover:bg-secondary-fixed-dim transition-all" type="submit">Subscribe</button>
        </form>
        <p class="font-label-sm text-label-sm opacity-70">No spam, just love letters. Unsubscribe at any time.</p>
      </div>
    </div>
  </section>

  <!-- Series Strip -->
  <section class="py-xl overflow-hidden">
    <div class="max-w-container-max mx-auto px-md">
      <div class="flex justify-between items-end mb-lg flex-wrap gap-md">
        <div>
          <h2 class="font-headline-md text-headline-md text-primary">The Pelican Cove Series</h2>
          <p class="font-body-md text-body-md text-on-surface-variant">All five books, in reading order.</p>
        </div>
        <a class="text-primary font-label-sm text-label-sm border-b border-primary pb-xs hover:opacity-70 transition-all" href={`${base}/books`}>See all</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-md">
        {[
          { slug: "the-worst-idea-yet", title: "The Worst Idea Yet" },
          { slug: "pretend-you-love-me", title: "Pretend You Love Me" },
          { slug: "the-wrong-brother", title: "The Wrong Brother" },
          { slug: "one-more-chance-to-ruin-this", title: "One More Chance to Ruin This" },
          { slug: "the-last-bad-decision", title: "The Last Bad Decision" }
        ].map((b) => (
          <a href={`${base}/books`} class="aspect-[2/3] rounded-lg overflow-hidden border border-outline-variant/30 group hover:shadow-lg transition-all">
            <img src={`${base}/covers/${b.slug}.png`} alt={`Cover of ${b.title}`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
